---
/**
 * /locations/[city]/[service]/[subservice] — the deepest combinatorial route (req #4).
 *
 * getStaticPaths() builds: every location × each category it offers × each
 * sub-service of that category. Because it iterates servicesForLocation(), a
 * city never generates sub-service pages for a category it doesn't serve — so
 * unavailable combinations are never created (req #9). Categories with no
 * sub-services (e.g. insulation) simply contribute nothing.
 */
import LocationSubServiceLayout from '../../../../layouts/LocationSubServiceLayout.astro';
import { locations } from '../../../../data/locations';
import { servicesForLocation, subServicesForCategory } from '../../../../lib/links';

export function getStaticPaths() {
  return locations.flatMap((location) =>
    servicesForLocation(location).flatMap((service) =>
      subServicesForCategory(service.slug).map((subService) => ({
        params: { city: location.slug, service: service.slug, subservice: subService.slug },
        props: { location, service, subService },
      })),
    ),
  );
}

const { location, service, subService } = Astro.props;
---

<LocationSubServiceLayout {location} {service} {subService} />
