---
/**
 * /services/[service]/[subservice] — one page per sub-service (req #3).
 *
 * getStaticPaths() fans out over the sub-service catalog, deriving the parent
 * category from each entry's `parent`. Add a sub-service to data/subservices.ts
 * and its page appears here — no new route file.
 */
import SubServiceLayout from '../../../layouts/SubServiceLayout.astro';
import { subServices } from '../../../data/subservices';
import { getService } from '../../../data/services';

export function getStaticPaths() {
  return subServices.flatMap((subService) => {
    const service = getService(subService.parent);
    // Skip orphaned sub-services whose parent category no longer exists.
    return service
      ? [{ params: { service: service.slug, subservice: subService.slug }, props: { service, subService } }]
      : [];
  });
}

const { service, subService } = Astro.props;
---

<SubServiceLayout {service} {subService} />
