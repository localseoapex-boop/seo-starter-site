---
/**
 * /services/[service] — one page per category (moved into a folder so sub-service
 * routes can nest beneath it at /services/[service]/[subservice]).
 *
 * getStaticPaths() fans out over the services catalog. Add a category to
 * data/services.ts and its page appears automatically.
 */
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { services } from '../../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<ServiceLayout {service} />
