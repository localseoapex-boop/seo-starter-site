---
/**
 * LocationSubServiceLayout.astro — /locations/[city]/[category]/[subservice] (req #4).
 *
 * The deepest page tier: a single sub-service in a single city. Data-driven from
 * Location + parent Service + SubService. Builds a 5-level breadcrumb
 * (Home › Locations › City › Category › Sub-service, req #7), city-scoped Service
 * JSON-LD with the serving office as provider (req #8), and internal links to
 * sibling sub-services in the same city and the same sub-service in nearby
 * cities that also offer the category (req #4 + #9).
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import InternalLinks from '../components/InternalLinks.astro';
import { SITE } from '../config/site';
import type { Location } from '../data/locations';
import type { Service } from '../data/services';
import type { SubService } from '../data/subservices';
import { getOffice, primaryOffice, officeNodeId } from '../data/offices';
import { subServicesForCategory, nearbyCities, isServiceAvailable } from '../lib/links';
import { cityUrl, locationServiceUrl, locationSubServiceUrl, absoluteUrl } from '../lib/urls';

interface Props {
  location: Location;
  service: Service;
  subService: SubService;
}

const { location, service, subService } = Astro.props;
const office = getOffice(location.officeId) ?? primaryOffice;

const cityState = `${location.city}, ${location.region}`;
const title = `${subService.name} in ${cityState}`;
const description = `${subService.description} Serving ${cityState}.`;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Locations', href: '/locations' },
  { name: cityState, href: cityUrl(location.slug) },
  { name: service.name, href: locationServiceUrl(location.slug, service.slug) },
  { name: subService.name },
];

// Sibling sub-services in this category, in this city.
const siblingLinks = subServicesForCategory(service.slug)
  .filter((s) => s.slug !== subService.slug)
  .map((s) => ({
    label: `${s.name} in ${location.city}`,
    href: locationSubServiceUrl(location.slug, service.slug, s.slug),
  }));

// Same sub-service in nearby cities that ALSO offer the parent category (req #9).
const nearbyLinks = nearbyCities(location.slug)
  .filter((loc) => isServiceAvailable(loc, service.slug))
  .map((loc) => ({
    label: `${subService.name} in ${loc.city}, ${loc.region}`,
    href: locationSubServiceUrl(loc.slug, service.slug, subService.slug),
  }));

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: subService.name,
  category: service.name,
  provider: { '@id': officeNodeId(SITE.url, office) },
  areaServed: { '@type': 'City', name: location.city },
  url: absoluteUrl(locationSubServiceUrl(location.slug, service.slug, subService.slug)),
};
---

<BaseLayout {title} {description}>
  <article class="container page">
    <Breadcrumbs items={crumbs} />

    <header class="page-hero">
      <p class="eyebrow">{cityState} · {service.name}</p>
      <h1>{title}</h1>
      <p class="lede">{subService.tagline}</p>
      <a class="cta" href={`tel:${office.phone}`}>Book {subService.name.toLowerCase()} — {office.phone}</a>
    </header>

    <div class="page-body">
      <p>
        Need {subService.name.toLowerCase()} in {cityState}? {subService.intro} Our {location.city}
        customers get upfront pricing and licensed technicians, dispatched from our {office.name}.
      </p>
      <h2>What's included</h2>
      <ul>
        {subService.features.map((f) => <li>{f}</li>)}
      </ul>
      <slot />
    </div>

    <InternalLinks title={`Other ${service.name} services in ${location.city}`} links={siblingLinks} />
    <InternalLinks title={`${subService.name} in nearby cities`} links={nearbyLinks} />

    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} is:inline />
  </article>
</BaseLayout>
