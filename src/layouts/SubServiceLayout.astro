---
/**
 * SubServiceLayout.astro — template for /services/[category]/[subservice] (req #3).
 *
 * Data-driven from a parent Service + a SubService. Builds a 4-level breadcrumb
 * (Home › Services › Category › Sub-service, req #7), Service JSON-LD scoped to
 * the sub-service (req #8), and internal links to sibling sub-services and to
 * this sub-service in each city that offers the parent category.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import InternalLinks from '../components/InternalLinks.astro';
import { BUSINESS, SITE } from '../config/site';
import type { Service } from '../data/services';
import type { SubService } from '../data/subservices';
import { subServicesForCategory, locationsForService } from '../lib/links';
import { serviceUrl, subServiceUrl, locationSubServiceUrl, absoluteUrl } from '../lib/urls';

interface Props {
  service: Service;
  subService: SubService;
}

const { service, subService } = Astro.props;

const title = subService.name;
const description = subService.description;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services' },
  { name: service.name, href: serviceUrl(service.slug) },
  { name: subService.name },
];

// Sibling sub-services within the same category.
const siblingLinks = subServicesForCategory(service.slug)
  .filter((s) => s.slug !== subService.slug)
  .map((s) => ({ label: s.name, href: subServiceUrl(service.slug, s.slug), description: s.tagline }));

// This sub-service in every city that offers the parent category (req #4 + #9).
const areaLinks = locationsForService(service.slug).map((loc) => ({
  label: `${subService.name} in ${loc.city}, ${loc.region}`,
  href: locationSubServiceUrl(loc.slug, service.slug, subService.slug),
}));

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: subService.name,
  category: service.name,
  provider: { '@id': `${SITE.url}/#business` },
  areaServed: BUSINESS.areaServed,
  url: absoluteUrl(subServiceUrl(service.slug, subService.slug)),
};
---

<BaseLayout {title} {description}>
  <article class="container page">
    <Breadcrumbs items={crumbs} />

    <header class="page-hero">
      <p class="eyebrow">{service.name}</p>
      <h1>{subService.name}</h1>
      <p class="lede">{subService.tagline}</p>
      <a class="cta" href={`tel:${BUSINESS.phone}`}>Get a free quote — {BUSINESS.phone}</a>
    </header>

    <div class="page-body">
      <p>{subService.intro}</p>
      <h2>What's included</h2>
      <ul>
        {subService.features.map((f) => <li>{f}</li>)}
      </ul>
      <slot />
    </div>

    <InternalLinks title={`More ${service.name} services`} links={siblingLinks} />
    <InternalLinks title={`${subService.name} in your area`} links={areaLinks} />

    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} is:inline />
  </article>
</BaseLayout>
